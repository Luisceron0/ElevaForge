# Supabase Configuration
# NEXT_PUBLIC_* keys are exposed to the browser
# SUPABASE_SERVICE_ROLE_KEY is server-only (used in API routes)
NEXT_PUBLIC_SUPABASE_URL=tu_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key

# Site URL (for metadata and CSRF origin validation)
NEXT_PUBLIC_SITE_URL=https://elevaforge.com

# WhatsApp Configuration
NEXT_PUBLIC_WHATSAPP_NUMBER=573XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hola ElevaForge, quiero iniciar mi proyecto digital

# Worker/Cron Authentication (REQUIRED — workers fail-closed without it)
CRON_SECRET=generate_a_strong_random_secret_here

# Discord Notifications (REQUIRED for lead processing worker)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Admin Panel Authentication
# Session signing seed (required in production)
ADMIN_SESSION_SEED=change_this_seed

# Legacy bootstrap admin (optional):
# Allows logging in once while migrating so you can create admins in Supabase.
# Remove these when at least one user exists in admin_users.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
