# Supabase Configuration (public keys only - service role key is in ElevaForgeBack)
NEXT_PUBLIC_SUPABASE_URL=tu_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key

# Backend API URL (ElevaForgeBack — required for lead submission to Supabase)
# Set this to the deployed URL of https://github.com/Luisceron0/ElevaForgeBack
# Examples:
#   Railway:  https://elevaforgeback-production.up.railway.app
#   Render:   https://elevaforgeback.onrender.com
#   Fly.io:   https://elevaforgeback.fly.dev
#   Local:    http://localhost:3001
NEXT_PUBLIC_API_URL=

# Site URL (for metadata)
NEXT_PUBLIC_SITE_URL=https://elevaforge.com

# WhatsApp Configuration
NEXT_PUBLIC_WHATSAPP_NUMBER=573XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hola ElevaForge, quiero iniciar mi proyecto digital
